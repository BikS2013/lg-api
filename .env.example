LG_API_PORT=8123
LG_API_HOST=0.0.0.0
LG_API_AUTH_ENABLED=true
LG_API_KEY=your-api-key-here

# Storage configuration (optional - defaults to in-memory if not set)
# STORAGE_CONFIG_PATH=./storage-config.yaml

# Azure Blob Storage (required when storage provider is azure-blob)
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net

# SQL Server (required when storage provider is sqlserver)
# SQLSERVER_HOST=localhost
# SQLSERVER_DATABASE=lgapi
# SQLSERVER_USER=sa
# SQLSERVER_PASSWORD=your-password
